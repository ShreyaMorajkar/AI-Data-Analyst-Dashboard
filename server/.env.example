OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini

# Auth
JWT_SECRET=replace_with_long_random_secret
# Production: set SMTP_* and FRONTEND_VERIFY_URL for email verification links.
# Demo deploy: set EMAIL_VERIFICATION_DISABLED=true to bypass verification emails.
EMAIL_VERIFICATION_DISABLED=false

MONGODB_URI=mongodb://127.0.0.1:27017/ai_data_analyst_dashboard
MONGODB_DB=ai_data_analyst_dashboard
PYTHON_SERVICE_URL=http://127.0.0.1:8000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_VERIFY_URL=http://localhost:5173
# Local dev: if SMTP_* are omitted, verification emails are sent via Ethereal (fake inbox); check server logs for preview URL.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=AI Dashboard <no-reply@yourdomain.com>
